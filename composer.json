{
    "name": "pausatf/results-manager",
    "description": "PA USATF Results Manager WordPress plugin",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "PA USATF",
            "email": "webmaster@pausatf.org"
        }
    ],
    "require": {
        "php": ">=8.4"
    },
    "require-dev": {
        "codeception/codeception": "^5.1",
        "codeception/module-webdriver": "^4.0",
        "cyclonedx/cyclonedx-php-composer": "^6.2",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^1.11",
        "phpunit/phpunit": "^11.0",
        "squizlabs/php_codesniffer": "^3.10",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "wp-coding-standards/wpcs": "^3.1"
    },
    "autoload": {
        "psr-4": {
            "PAUSATF\\Results\\": "includes/",
            "PAUSATF\\Results\\Contracts\\": "includes/contracts/",
            "PAUSATF\\Results\\Models\\": "includes/models/",
            "PAUSATF\\Results\\Parsers\\": "includes/parsers/",
            "PAUSATF\\Results\\Sanctions\\": "includes/sanctions/",
            "PAUSATF\\Results\\Storage\\": "includes/storage/",
            "PAUSATF\\Results\\Rules\\": "includes/rules/",
            "PAUSATF\\Results\\Integrations\\": "includes/integrations/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PAUSATF\\Results\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "phpcs --standard=WordPress .",
        "lint:fix": "phpcbf --standard=WordPress .",
        "analyze": "phpstan analyse",
        "test": "phpunit",
        "test:e2e": "codecept run",
        "test:coverage": "phpunit --coverage-html coverage",
        "hooks:install": "git config core.hooksPath .githooks",
        "sbom": "composer CycloneDX:make-sbom --output-format=JSON --output-file=sbom.cdx.json",
        "sbom:xml": "composer CycloneDX:make-sbom --output-format=XML --output-file=sbom.cdx.xml",
        "security:audit": "composer audit --format=json > security-audit.json",
        "security:check": [
            "@security:audit",
            "@sbom"
        ]
    },
    "config": {
        "allow-plugins": {
            "cyclonedx/cyclonedx-php-composer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true
        },
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "extra": {
        "wordpress-plugin-dir": "wp-content/plugins/pausatf-results-manager",
        "cyclonedx": {
            "spec-version": "1.5",
            "output-format": "JSON",
            "exclude-dev": false,
            "exclude-plugins": false
        }
    }
}
