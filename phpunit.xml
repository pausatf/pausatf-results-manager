<?xml version="1.0" encoding="UTF-8"?>
<phpunit bootstrap="tests/bootstrap.php" backupGlobals="false" colors="true" cacheDirectory=".phpunit.cache">
  <testsuites>
    <testsuite name="PAUSATF Results Manager">
      <directory suffix="Test.php">./tests</directory>
    </testsuite>
  </testsuites>
  <php>
    <const name="PAUSATF_TESTING" value="true"/>
  </php>
  <source>
    <include>
      <directory suffix=".php">./includes</directory>
      <directory suffix=".php">./public</directory>
    </include>
  </source>
</phpunit>
