{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.pausatf.org/schemas/pausatf-event.schema.json",
  "title": "PAUSATF canonical event",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_uid", "name"],
  "properties": {
    "@context": { "type": "string" },
    "@type": { "type": ["string", "array"] },
    "@id": { "type": "string" },
    "url": { "type": "string", "format": "uri" },
    "event_uid": { "type": "string", "minLength": 3 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "date": { "type": "string", "format": "date" },
    "startDate": { "type": "string", "format": "date-time" },
    "endDate": { "type": "string", "format": "date-time" },
    "eventStatus": { "type": "string" },
    "eventAttendanceMode": { "type": "string" },
    "discipline": { "type": "string" },
    "series": { "type": ["string", "array"] },
    "season": { "type": ["string", "integer"] },
    "event_type": { "type": "string" },
    "divisions": { "type": "array", "items": { "type": "string" } },
    "location": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "hasMap": { "type": "string", "format": "uri" },
        "address": { "type": "object", "additionalProperties": true }
      },
      "additionalProperties": false
    },
    "organizer": { "type": ["string", "object"] },
    "registration_url": { "type": "string", "format": "uri" },
    "registration_status": { "type": "string" },
    "source": { "type": "object", "additionalProperties": true },
    "source_url": { "type": "string", "format": "uri" },
    "source_site": { "type": "string" },
    "source_hash": { "type": "string" },
    "import_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "review_status": { "type": "string" },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["athlete_name"],
        "properties": {
          "athlete_name": { "type": "string" },
          "athlete_uid": { "type": "string" },
          "athlete_source_id": { "type": "string" },
          "athlete": { "type": "object", "additionalProperties": true },
          "place": { "type": ["integer", "null"] },
          "division": { "type": ["string", "null"] },
          "division_place": { "type": ["integer", "null"] },
          "sex": { "type": ["string", "null"] },
          "athlete_age": { "type": ["integer", "null"] },
          "time_seconds": { "type": ["integer", "null"] },
          "time_display": { "type": ["string", "null"] },
          "points": { "type": ["number", "null"] },
          "payout": { "type": ["number", "null"] },
          "club": { "type": ["string", "null"] },
          "bib": { "type": ["string", "null"] },
          "pace": { "type": ["string", "null"] }
        },
        "additionalProperties": true
      }
    }
  }
}
